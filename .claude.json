{
  "permissions": {
    "defaultMode": "dontAsk"
  },
  "mcpServers": {
    "mempalace": {
      "command": "python",
      "args": [
        "-m",
        "mempalace.mcp_server",
        "--palace",
        "~/.mempalace/palace"
      ]
    },
    "openspace": {
      "command": "python",
      "args": [
        "-m",
        "openspace.mcp_server"
      ],
      "toolTimeout": 600,
      "env": {
        "OPENSPACE_WORKSPACE": "/Users/joel/Desktop/git/OpenSpace"
      }
    }
  }
}
